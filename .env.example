# --- Gungnir Universal Reasoning Config ---
# Realm Selection: local, cloud, enterprise
GUNGNIR_REASONING_REALM=local

# Edge Realm (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Cloud Realm (OpenAI / Anthropic)
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Enterprise Realm (Azure OpenAI)
AZURE_OPENAI_API_KEY=your_azure_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name

# --- Enterprise Security (SSO/RBAC) ---
SSO_ENABLED=false
OIDC_ISSUER_URL=https://your-issuer-url.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
RBAC_STRICT_MODE=true

# --- Module Endpoints ---
GUNGNIR_CORE_URL=http://localhost:8000
MJOLNIR_FABRIC_URL=http://localhost:6333
BIFROST_GATE_URL=http://localhost:8001
VALKYRIE_INTEGRATIONS_URL=http://localhost:8002
